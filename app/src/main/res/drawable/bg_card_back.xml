<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="@color/card_back_start"
                android:endColor="@color/card_back_end"
                android:type="linear" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="@color/card_back_start"
                android:endColor="@color/card_back_end"
                android:type="linear" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</layer-list>
